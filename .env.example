# Keep the deterministic M4 path unless LLM integration is explicitly enabled.
LLM_ENABLED=false

# Main answer model: local vLLM or any OpenAI-compatible API.
MAIN_LLM_BASE_URL=http://127.0.0.1:8000/v1
MAIN_LLM_API_KEY=replace-with-api-key
MAIN_LLM_MODEL=replace-with-main-model
MAIN_LLM_TIMEOUT=30
# Model capability limit, not the amount sent on every request.
MAIN_LLM_CONTEXT_WINDOW=128000
# Maximum generated tokens for one final answer.
MAIN_LLM_MAX_TOKENS=2048
# Practical evidence and memory budget assembled by the Agent.
AGENT_MAX_CONTEXT_CHARS=16000

# Optional fallback endpoint for the main model.
MAIN_LLM_FALLBACK_BASE_URL=
MAIN_LLM_FALLBACK_API_KEY=
MAIN_LLM_FALLBACK_MODEL=

# Optional utility model used by the LLM Planner.
UTILITY_LLM_BASE_URL=
UTILITY_LLM_API_KEY=
UTILITY_LLM_MODEL=
UTILITY_LLM_TIMEOUT=15

# Finite attempts per endpoint.
LLM_MAX_ATTEMPTS=2

# Session memory: SQLite for local tests, PostgreSQL for deployment.
MEMORY_BACKEND=sqlite
MEMORY_SQLITE_PATH=enterprise_agent/data/memory.db
MEMORY_POSTGRES_URL=
MEMORY_MAX_RECENT_TURNS=10
MEMORY_MAX_CONTEXT_TOKENS=2000
MEMORY_LOCK_TIMEOUT=10
